# =============================================================================
# Local + Vercel environment
# =============================================================================
# Copy to .env and fill in values.
#
# Preview (Remotion Player) works without Lambda.
# Local MP4 export needs FFmpeg on PATH.
# Vercel MP4 export needs Remotion Lambda (see scripts/setup-vercel-lambda.md).

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Better Auth — generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Neon Postgres
DATABASE_URL=

# GitHub OAuth App — https://github.com/settings/developers
# Authorization callback URL: {BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Remotion Lambda (optional locally; required for MP4 export on Vercel) ---
# REMOTION_AWS_ACCESS_KEY_ID=
# REMOTION_AWS_SECRET_ACCESS_KEY=
# REMOTION_AWS_REGION=us-east-1
# REMOTION_AWS_FUNCTION_NAME=
# REMOTION_SERVE_URL=
