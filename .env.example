# =============================================================================
# Local + Vercel environment
# =============================================================================
# Copy to .env and fill in values.
#
# MP4 export runs entirely in the user's browser (WebCodecs) — no AWS / FFmpeg.

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Better Auth — generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Neon Postgres
DATABASE_URL=

# GitHub OAuth App — https://github.com/settings/developers
# Authorization callback URL: {BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
