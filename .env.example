# =============================================================================
# Vercel deployment
# =============================================================================
# 1. Push repo to GitHub → import in Vercel (https://vercel.com/new)
# 2. Set these env vars in Vercel → Project → Settings → Environment Variables
# 3. Run Lambda setup ONCE from your machine (see npm scripts below)
# 4. Redeploy after adding env vars
#
# Preview (Player) works without Lambda.
# MP4 export on Vercel REQUIRES Remotion Lambda — local FFmpeg render does not
# work on serverless.

NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# Better Auth — generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth App — https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Remotion Lambda (required for MP4 export on Vercel) ---
# Create AWS IAM user + run: npm run lambda:deploy && npm run lambda:site
# Docs: https://www.remotion.dev/docs/lambda/setup

REMOTION_AWS_ACCESS_KEY_ID=
REMOTION_AWS_SECRET_ACCESS_KEY=
REMOTION_AWS_REGION=us-east-1

# Output of: npm run lambda:deploy
REMOTION_AWS_FUNCTION_NAME=

# Output of: npm run lambda:site (Serve URL)
REMOTION_SERVE_URL=